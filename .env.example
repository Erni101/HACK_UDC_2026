# Variables de entorno para el proyecto HACK_UDC_2026
# Copia este archivo a .env y rellena los valores:
#   cp .env.example .env

# Nombre del proyecto (informativo)
PROJECT_NAME=HACK_UDC_2026

# Entorno: development | production
ENV=development

# Ruta al dataset principal (relativa a la raíz del proyecto)
DATA_PATH=data/raw/dataset.csv

# Semilla para reproducibilidad de resultados aleatorios
RANDOM_SEED=42

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
